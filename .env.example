# Confluence Retriever — Configuration Template
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Setup:
#   cp .env.example .env
#   # Then edit .env with your actual PAT

# Confluence instance base URL (no trailing slash)
CONFLUENCE_URL=https://your-confluence-instance.com

# Personal Access Token — generate at:
# https://your-confluence-instance.com/plugins/servlet/de.resolution.apitokenauth/admin
CONFLUENCE_PAT=your_personal_access_token_here
